<script>
// ─── COUNTER ANIMATION ───
const metrics = document.querySelectorAll('.metric');
const counterEls = document.querySelectorAll('[data-target]');
function animCount(el){
  const target = parseFloat(el.dataset.target);
  const suffix = el.dataset.suffix||'';
  const prefix = el.dataset.prefix||'';
  const dec = parseInt(el.dataset.dec||'0');
  const sep = el.dataset.sep==='true';
  const dur = 1400;
  const start = performance.now();
  (function step(now){
    const p = Math.min((now-start)/dur,1);
    const e = 1-Math.pow(1-p,3);
    const v = target*e;
    let s = dec>0 ? v.toFixed(dec) : Math.floor(v).toString();
    if(sep) s = parseInt(s).toLocaleString('en-US');
    el.textContent = prefix+s+suffix;
    if(p<1) requestAnimationFrame(step);
  })(start);
}
const mObs = new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.classList.add('visible');
      const strong = e.target.querySelector('[data-target]');
      if(strong) animCount(strong);
      mObs.unobserve(e.target);
    }
  });
},{threshold:.3});
metrics.forEach(m=>mObs.observe(m));

// ─── SCROLL REVEAL ───
const revObs = new IntersectionObserver(entries=>{
  entries.forEach(e=>{ if(e.isIntersecting){e.target.classList.add('on');revObs.unobserve(e.target)} });
},{threshold:.12});
document.querySelectorAll('.reveal').forEach(r=>revObs.observe(r));

// ─── TERMINAL LOOP ───
const lines = [
  {t:'[boot] loading league scanners · EPL / UCL / UEL / Liga / BL',c:''},
  {t:'[scan] fetching fixtures next 48h window...',c:''},
  {t:'[ref]  referee intelligence layer loaded · 1,842 profiles',c:''},
  {t:'[ppi]  computing Penalty Pressure Index for 24 fixtures...',c:''},
  {t:'[dvs]  Defensive Vulnerability Score pass completed',c:''},
  {t:'[mkt]  bookmaker sweep · 6 sources aggregated',c:''},
  {t:'[calc] calibrating fair-odds vs market spread...',c:''},
  {t:'[conf] confidence layer = DONNÉES OK',c:''},
  {t:'[ref]  referee strictness variance · within range',c:''},
  {t:'[score] Mallorca vs Real Madrid · 84 / 100',c:''},
  {t:'✅ SIGNAL DETECTED · edge validated · Telegram push queued',c:'green'},
  {t:'[stake] bankroll staging: SIGNAL / 6u',c:''},
  {t:'[next] loading next fixture batch...',c:''},
  {t:'[mkt]  anomaly: bookmaker spread widening on UCL fixture',c:''},
  {t:'[uel]  Europa League market sweep in progress...',c:''},
  {t:'✅ OPPORTUNITY LOCKED · dispatch to premium room',c:'green'},
];
const termOut = document.getElementById('termOut');
let lineIdx=0, running=true;
function addLine(){
  if(!running) return;
  const l = lines[lineIdx % lines.length];
  lineIdx++;
  const span = document.createElement('span');
  span.className='code-line'+(l.c?' '+l.c:'');
  span.textContent=l.t;
  termOut.appendChild(span);
  // keep only last 10 lines visible
  const all = termOut.querySelectorAll('.code-line');
  if(all.length>10){ all[0].remove(); }
  setTimeout(addLine, lineIdx%lines.length===0 ? 1800 : 480);
}
setTimeout(addLine, 600);

// ─── TELEGRAM ANIMATION ───
const tgMsgs = document.getElementById('tgMsgs');
const LOGO = "data:image/jpeg;base64,";

function showTgSignal(){
  tgMsgs.innerHTML='';
  const bubble = document.createElement('div');
  bubble.className='tg-bubble';
  bubble.style.animationDelay='0.1s';
  bubble.innerHTML=`
    <div class="row">
      <img src="${LOGO}" alt="P" />
      <strong>PENALBOT Premium</strong>
    </div>
    🚨 <strong>Premium signal detected</strong><br>
    <br>
    📋 <strong>Match :</strong> Mallorca vs Real Madrid<br>
    🏆 <strong>League :</strong> La Liga<br>
    📊 <strong>Score :</strong> 84 / 100<br>
    🎯 <strong>Penalty proba :</strong> 31.8%<br>
    💰 <strong>Suggested stake :</strong> 6u
    <div class="signal-inner">
      <strong>✅ Key factors</strong>
      Favourable referee · high offensive pressure · adverse defensive vulnerability · market still exploitable.
    </div>
    <span class="tg-time">Today 13:35</span>
  `;
  tgMsgs.appendChild(bubble);
}

showTgSignal();
setInterval(()=>{
  tgMsgs.style.opacity='0';
  tgMsgs.style.transition='opacity .4s';
  setTimeout(()=>{
    showTgSignal();
    tgMsgs.style.opacity='1';
  },450);
}, 7000);

// ─── NAV ACTIVE STATE ───
const sections=['about','technology','pricing'];
const navLinks=document.querySelectorAll('.nav-links a');
window.addEventListener('scroll',()=>{
  let cur='';
  sections.forEach(id=>{
    const s=document.getElementById(id);
    if(s && window.scrollY>=s.offsetTop-120) cur=id;
  });
  navLinks.forEach(a=>{
    a.classList.toggle('active',a.getAttribute('href')==='#'+cur||(cur===''&&a.getAttribute('href')==='#about'));
  });
},{passive:true});
</script>
</body>
</html>
